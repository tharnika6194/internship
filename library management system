#include <iostream>
#include <fstream>
#include <iomanip>
#include <cstring>
using namespace std;
class Book {
private:
    int bookID;
    char title[50];
    char author[50];
    bool issued;
public:
    void addBook() {
        cout << "\nEnter Book ID: ";
        cin >> bookID;
        cin.ignore();
        cout << "Enter Book Title: ";
        cin.getline(title, 50);
        cout << "Enter Author Name: ";
        cin.getline(author, 50);
        issued = false;
    }
    void displayBook() const {
        cout << left << setw(10) << bookID
             << setw(30) << title
             << setw(25) << author
             << setw(10) << (issued ? "Issued" : "Available")
             << endl;
    }
    int getBookID() const {
        return bookID;
    }
    const char* getTitle() const {
        return title;
    }
    const char* getAuthor() const {
        return author;
    }
    bool isIssued() const {
        return issued;
    }
    bool issueBook() {
        if (issued)
            return false;

        issued = true;
        return true;
    }

    bool returnBook() {
        if (!issued)
            return false;

        issued = false;
        return true;
    }
};
void addNewBook() {
    Book b;
    ofstream outFile("library.dat", ios::binary | ios::app);
    b.addBook();
    outFile.write(reinterpret_cast<char*>(&b), sizeof(b));
    outFile.close();
    cout << "\nBook Added Successfully!\n";
}
void displayBooks() {
    Book b;
    ifstream inFile("library.dat", ios::binary);
    if (!inFile) {
        cout << "\nNo Records Found!\n";
        return;
    }

    cout << "\n----------------------------------------------------------------------------\n";
    cout << left << setw(10) << "Book ID"
         << setw(30) << "Title"
         << setw(25) << "Author"
         << setw(10) << "Status" << endl;

    cout << "----------------------------------------------------------------------------\n";

    while (inFile.read(reinterpret_cast<char*>(&b), sizeof(b))) {
        b.displayBook();
    }

    inFile.close();
}
void searchByTitle() {
    Book b;
    char searchTitle[50];
    bool found = false;

    ifstream inFile("library.dat", ios::binary);

    cin.ignore();

    cout << "\nEnter Title to Search: ";
    cin.getline(searchTitle, 50);

    while (inFile.read(reinterpret_cast<char*>(&b), sizeof(b))) {

        if (strcmp(b.getTitle(), searchTitle) == 0) {

            cout << "\nBook Found:\n";

            cout << "----------------------------------------------------------------------------\n";
            cout << left << setw(10) << "Book ID"
                 << setw(30) << "Title"
                 << setw(25) << "Author"
                 << setw(10) << "Status" << endl;
            cout << "----------------------------------------------------------------------------\n";
            b.displayBook();
            found = true;
        }
    }
    inFile.close();
    if (!found) {
        cout << "\nBook Not Found!\n";
    }
}
void searchByAuthor() {
    Book b;
    char searchAuthor[50];
    bool found = false;
    ifstream inFile("library.dat", ios::binary);
    cin.ignore();
    cout << "\nEnter Author Name to Search: ";
    cin.getline(searchAuthor, 50);
    while (inFile.read(reinterpret_cast<char*>(&b), sizeof(b))) {
        if (strcmp(b.getAuthor(), searchAuthor) == 0) {
            cout << "\nBook Found:\n";
            cout << "----------------------------------------------------------------------------\n";
            cout << left << setw(10) << "Book ID"
                 << setw(30) << "Title"
                 << setw(25) << "Author"
                 << setw(10) << "Status" << endl;
            cout << "----------------------------------------------------------------------------\n";
            b.displayBook();
            found = true;
        }
    }
    inFile.close();
    if (!found) {
        cout << "\nNo Books Found by This Author!\n";
    }
}
void issueBook() {
    Book b;
    int id;
    bool found = false;
    fstream file("library.dat", ios::binary | ios::in | ios::out);
    cout << "\nEnter Book ID to Issue: ";
    cin >> id;
    while (file.read(reinterpret_cast<char*>(&b), sizeof(b))) {
        if (b.getBookID() == id) {
            if (b.issueBook()) {
                int pos = (-1) * static_cast<int>(sizeof(b));
                file.seekp(pos, ios::cur);
                file.write(reinterpret_cast<char*>(&b), sizeof(b));
                cout << "\nBook Issued Successfully!\n";
            } else {
                cout << "\nBook Already Issued!\n";
            }
            found = true;
            break;
        }
    }
    file.close();
    if (!found) {
        cout << "\nBook Not Found!\n";
    }
}
void returnBook() {
    Book b;
    int id;
    bool found = false;
    fstream file("library.dat", ios::binary | ios::in | ios::out);
    cout << "\nEnter Book ID to Return: ";
    cin >> id;
    while (file.read(reinterpret_cast<char*>(&b), sizeof(b))) {
        if (b.getBookID() == id) {
            if (b.returnBook()) {
                int pos = (-1) * static_cast<int>(sizeof(b));
                file.seekp(pos, ios::cur);
                file.write(reinterpret_cast<char*>(&b), sizeof(b));
                cout << "\nBook Returned Successfully!\n";
            } else {
                cout << "\nBook Was Not Issued!\n";
            }
            found = true;
            break;
        }
    }
    file.close();
    if (!found) {
        cout << "\nBook Not Found!\n";
    }
}
